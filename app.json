{
  "expo": {
    "name": "Voda",
    "slug": "voda-mobile-app",
    "scheme": "voda",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ppiyakworld.voda",
      "associatedDomains": [
        "applinks:voda.ppiyakworld.com"
      ]
    },
    "android": {
      "package": "com.ppiyakworld.voda",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "voda",
              "host": "auth",
              "pathPrefix": "/verified"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "voda.ppiyakworld.com",
              "pathPrefix": "/auth/verified"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "androidStatusBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content",
      "translucent": false
    }
  }
}
